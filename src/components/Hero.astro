---
import { hero } from "../data/content";
---

<section class="relative pt-6 lg:pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img
            src="/images/fondo_hero.webp"
            alt="Fondo de restaurante"
            class="w-full h-full object-cover opacity-30"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-slate-50/40 via-slate-50/30 to-slate-50/40"
        >
        </div>
    </div>

    <!-- Bottom Fade Gradient -->
    <div
        class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-slate-50 to-transparent z-10"
    >
    </div>

    <!-- Decorative blob -->
    <div
        class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-3xl opacity-5 animate-pulse-slow pointer-events-none"
        style="background: var(--color-terracotta);"
    >
    </div>

    <div class="relative z-10 container-narrow w-full section-padding">
        <div class="flex flex-col items-center text-center">
            <!-- Badge -->
            <div
                class="inline-flex items-center gap-2 px-3 sm:px-4 py-1.5 sm:py-2 rounded-full bg-brand-900 mb-6 shadow-lg shadow-brand-900/20 animate-fade-in-up hover:scale-105 transition-transform duration-300"
                style="border: 1px solid rgba(243, 93, 9, 0.5);"
            >
                <div class="relative flex items-center justify-center">
                    <span
                        class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse absolute inline-flex"
                    ></span>
                    <span
                        class="w-2 h-2 rounded-full bg-emerald-400 relative inline-flex opacity-75"
                    ></span>
                </div>
                <span
                    class="text-[10px] sm:text-xs md:text-sm font-bold text-white uppercase tracking-wider"
                    >Paquete Restaurante de Éxito</span
                >
            </div>

            <!-- Headline -->
            <h1
                class="text-3xl sm:text-5xl lg:text-6xl font-black leading-tight mb-8 sm:mb-10 animate-fade-in-up animate-delay-100 max-w-5xl px-2 sm:px-0"
            >
                <span class="text-brand-900 block mb-1 sm:mb-2"
                    >Abre Tu Restaurante</span
                >
                <span
                    class="text-transparent bg-clip-text"
                    style="background: linear-gradient(to right, #f35d09, #f30606); -webkit-background-clip: text; background-clip: text;"
                >
                    Como Un Profesional
                </span>
                <span
                    class="block text-xl sm:text-3xl lg:text-4xl mt-2 sm:mt-3 text-brand-800"
                    >— Sin Perder Tiempo ni Dinero en el Intento</span
                >
            </h1>

            <!-- Video Section -->
            <div
                class="w-full max-w-5xl relative animate-fade-in-up animate-delay-200 mb-10 sm:mb-12"
            >
                <div
                    class="relative rounded-2xl overflow-hidden shadow-2xl shadow-brand-900/10 border border-brand-900/5 group"
                >
                    <div class="aspect-video bg-black relative">
                        <video
                            class="w-full h-full object-cover"
                            poster={hero.videoThumbnail}
                            controls
                            autoplay
                            muted
                            loop
                            playsinline
                        >
                            <source
                                src="/video_hero_compressed.mp4"
                                type="video/mp4"
                            />
                            Tu navegador no soporta video HTML5.
                        </video>
                    </div>
                </div>

                <!-- Decorative elements behind video -->
                <div
                    class="absolute -z-10 -bottom-10 -right-10 w-40 h-40 bg-mango/20 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="absolute -z-10 top-10 -left-10 w-40 h-40 bg-terracotta/20 rounded-full blur-3xl"
                >
                </div>
            </div>

            <!-- Subheadline -->
            <p
                class="text-xl text-brand-600 mb-6 max-w-2xl animate-fade-in-up animate-delay-200"
            >
                {hero.subheadline}
            </p>

            <!-- Target audience callout -->
            <div
                class="flex flex-wrap justify-center gap-3 mb-10 animate-fade-in-up animate-delay-250"
            >
                <span
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-brand-700 text-sm font-medium"
                    style="background: rgba(243, 93, 9, 0.1); border: 1px solid rgba(243, 93, 9, 0.2);"
                >
                    🚀 ¿Vas a abrir tu restaurante?
                </span>
                <span
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-brand-700 text-sm font-medium"
                    style="background: rgba(243, 6, 6, 0.1); border: 1px solid rgba(243, 6, 6, 0.2);"
                >
                    📈 ¿Quieres mejorar el que ya tienes?
                </span>
            </div>

            <!-- CTA -->
            <div
                class="animate-fade-in-up animate-delay-300 flex flex-col items-center gap-4"
            >
                <a
                    href="#precio"
                    class="btn-cta text-lg shadow-xl shadow-orange-500/20 hover:shadow-orange-500/30 transform hover:-translate-y-1 transition-all duration-300 w-full sm:w-auto text-center"
                    data-track="hero_cta_click"
                >
                    Estoy listo para el éxito
                    <span class="ml-2">→</span>
                </a>

                <p
                    class="text-brand-700 font-semibold text-sm sm:text-base mb-1"
                >
                    Inversión de $5000 USD — Todo incluido <span
                        class="text-brand-500 text-xs">(+$99 envío)</span
                    >
                </p>

                <p
                    class="text-brand-600 font-medium text-xs sm:text-sm bg-brand-50/50 px-4 py-1.5 rounded-full border border-brand-100 flex items-center gap-2"
                >
                    🍽️ Más de 200 restauranteros en EE.UU. ya confían en
                    nosotros
                </p>

                <div class="flex flex-col sm:flex-row gap-3 items-center mt-2">
                    <a
                        href="#paquete"
                        class="text-brand-500 hover:text-brand-800 text-xs sm:text-sm font-medium underline underline-offset-4 transition-colors"
                        data-track="hero_secondary_cta_click"
                    >
                        Ver Qué Incluye el Paquete
                    </a>
                    <span class="hidden sm:inline text-brand-300">•</span>
                    <a
                        href="#reviews"
                        class="text-brand-500 hover:text-brand-800 text-xs sm:text-sm font-medium underline underline-offset-4 transition-colors flex items-center gap-1"
                        data-track="hero_reviews_cta_click"
                    >
                        <span class="text-lg leading-none">▶️</span>
                        Mira Lo Que Dicen Nuestros Clientes
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
